{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:forensic-agent-skills:schema:finding-record:1.0",
  "title": "Finding Record",
  "description": "Phase 2 统一发现记录格式",
  "type": "object",
  "additionalProperties": false,
  "required": ["finding_id", "description", "confidence", "evidence_refs", "schema_version"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "finding_id": {
      "type": "string",
      "pattern": "^finding-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "description": { "type": "string" },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^led-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      }
    },
    "category": {
      "type": ["string", "null"],
      "enum": ["acquisition", "analysis", "validation", "negative", null]
    },
    "related_skill": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
