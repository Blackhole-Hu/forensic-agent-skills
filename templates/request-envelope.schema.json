{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:forensic-agent-skills:schema:request-envelope:1.0",
  "title": "Request Envelope",
  "description": "Phase 2 统一请求信封格式",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_info", "objective", "objective_status", "context", "payload"],
      "properties": {
        "material_info": {
          "type": "object",
          "additionalProperties": false,
          "required": ["artifact_refs", "material_type", "triage_notes"],
          "properties": {
            "artifact_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
              }
            },
            "material_type": { "type": "string" },
            "triage_notes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size_summary": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "properties": {
                "total_bytes": { "type": ["integer", "null"], "minimum": 0 },
                "file_count": { "type": ["integer", "null"], "minimum": 0 },
                "largest_file_bytes": { "type": ["integer", "null"], "minimum": 0 }
              }
            }
          }
        },
        "objective": { "type": ["string", "null"] },
        "objective_status": {
          "type": "string",
          "enum": ["explicit", "inferred", "unknown"]
        },
        "context": { "type": ["object", "null"] },
        "payload": { "type": "object" }
      }
    }
  }
}
