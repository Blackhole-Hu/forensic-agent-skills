{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:forensic-agent-skills:schema:timeline-event:1.0",
  "title": "Timeline Event",
  "description": "Phase 2 时间线事件格式",
  "type": "object",
  "oneOf": [
    {
      "title": "Legacy v1.0 timeline event",
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "timeline_event_id", "source_type", "source_artifact_id", "parser_id", "action", "confidence", "time_precision", "ledger_event_refs"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "timeline_event_id": {
          "type": "string",
          "pattern": "^tl-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "original_timestamp": { "type": ["string", "null"] },
        "normalized_timestamp": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "timezone_offset": {
          "type": ["string", "null"],
          "pattern": "^[+-](0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "timezone_name": { "type": ["string", "null"] },
        "timezone_assumption": { "type": ["string", "null"] },
        "clock_skew_seconds": { "type": ["integer", "null"] },
        "time_precision": {
          "type": "string",
          "enum": ["exact", "second", "minute", "day", "unknown"]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "auth-log", "journal", "web-log", "docker-log",
            "db-transaction-log", "db-snapshot", "login-record",
            "file-time", "pve-log", "ceph-log"
          ]
        },
        "source_artifact_id": {
          "type": "string",
          "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "parser_id": { "type": "string", "minLength": 1 },
        "parser_version": { "type": ["string", "null"] },
        "actor": { "type": ["string", "null"] },
        "action": { "type": "string", "minLength": 1 },
        "target": { "type": ["string", "null"] },
        "ledger_event_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^led-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      },
      "anyOf": [
        {
          "required": ["original_timestamp"],
          "properties": {
            "original_timestamp": { "type": "string", "minLength": 1 }
          }
        },
        {
          "required": ["normalized_timestamp"],
          "properties": {
            "normalized_timestamp": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    {
      "title": "Phase 2 complete timeline event",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "timeline_event_id", "original_timestamp",
        "normalized_timestamp", "timezone_offset", "timezone_name",
        "timezone_assumption", "clock_skew_seconds", "time_precision",
        "normalization_status", "derivation", "source_type",
        "source_subtype", "source_artifact_id", "parser_id",
        "parser_version", "actor", "action", "target", "artifact_refs",
        "ledger_event_refs", "finding_refs", "basis", "confidence",
        "cluster_scope_id"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "timeline_event_id": {
          "type": "string",
          "pattern": "^tl-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "original_timestamp": { "type": ["string", "null"] },
        "normalized_timestamp": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "timezone_offset": {
          "type": ["string", "null"],
          "pattern": "^[+-](0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "timezone_name": { "type": ["string", "null"] },
        "timezone_assumption": { "type": ["string", "null"] },
        "clock_skew_seconds": { "type": ["integer", "null"] },
        "time_precision": {
          "type": "string",
          "enum": ["exact", "second", "minute", "day", "unknown"]
        },
        "normalization_status": {
          "type": "string",
          "enum": ["ready", "needs-review", "unsupported-source"]
        },
        "derivation": {
          "type": "string",
          "enum": ["observed", "inferred"]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "auth-log", "journal", "web-log", "docker-log",
            "db-transaction-log", "db-snapshot", "login-record",
            "file-time", "pve-log", "ceph-log", "audit-log",
            "package-log", "service-log", "cluster-log", "other"
          ]
        },
        "source_subtype": { "type": ["string", "null"] },
        "source_artifact_id": {
          "type": ["string", "null"],
          "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "parser_id": { "type": "string", "minLength": 1 },
        "parser_version": { "type": ["string", "null"] },
        "actor": { "type": ["string", "null"] },
        "action": { "type": "string", "minLength": 1 },
        "target": { "type": ["string", "null"] },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "ledger_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^led-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "finding_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^finding-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "basis": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "cluster_scope_id": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "required": ["derivation"],
            "properties": { "derivation": { "const": "observed" } }
          },
          "then": {
            "properties": {
              "source_artifact_id": {
                "type": "string",
                "pattern": "^artifact-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
              }
            }
          }
        },
        {
          "if": {
            "required": ["derivation"],
            "properties": { "derivation": { "const": "inferred" } }
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "basis": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              },
              {
                "properties": {
                  "ledger_event_refs": { "type": "array", "minItems": 1 }
                }
              }
            ]
          }
        },
        {
          "if": {
            "required": ["normalization_status"],
            "properties": { "normalization_status": { "const": "ready" } }
          },
          "then": {
            "properties": {
              "normalized_timestamp": {
                "type": "string",
                "minLength": 1,
                "format": "date-time"
              }
            }
          }
        },
        {
          "if": {
            "required": ["normalized_timestamp"],
            "properties": { "normalized_timestamp": { "type": "null" } }
          },
          "then": {
            "properties": {
              "normalization_status": {
                "enum": ["needs-review", "unsupported-source"]
              }
            }
          }
        }
      ]
    }
  ]
}
